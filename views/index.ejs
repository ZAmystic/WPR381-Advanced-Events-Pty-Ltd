<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Smart Event Platform</title>

    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <!-- NAVBAR -->
    <%- include('partials/navbar') %>

    <!-- HERO -->
    <section class="hero">
        <h1>Discover Amazing Events</h1>

        <p>
            Book conferences, festivals, workshops and more.
        </p>

        <a href="#events">
        <button>Explore Events</button>
        </a>

    </section>

    <!-- SEARCH & FILTER -->
<section class="search-section">
    <form class="search-form">
        <input
            type="text"
            placeholder="Search events..."
        >

        <select>
            <option>All Categories</option>
            <option>Conference</option>
            <option>Festival</option>
            <option>Workshop</option>
        </select>

        <input type="date">

        <button type="submit">Search</button>
    </form>
</section>

    <!-- EVENTS -->
    <section id="events" class="events">

        <div class="event-card">
            <img src="https://picsum.photos/300/200?1">

            <h3>Music Festival</h3>

            <p>Date: 12 June 2026</p>

            <a href="/events/1"><button>Book Now</button></a>
        </div>

        <div class="event-card">
            <img src="https://picsum.photos/300/200?2">

            <h3>Tech Conference</h3>

            <p>Date: 20 July 2026</p>

            <a href="/events/2"><button>Book Now</button></a>
        </div>

        <div class="event-card">
            <img src="https://picsum.photos/300/200?3">

            <h3>Business Workshop</h3>

            <p>Date: 5 August 2026</p>

            <a href="/events/3"><button>Book Now</button></a>
        </div>

    </section>

    <!-- FOOTER -->
    <%- include('partials/footer') %>

</body>
</html>