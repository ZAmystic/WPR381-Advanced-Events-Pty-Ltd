# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local development
MONGO_URI=mongodb://localhost:27017/advanced_events

# MongoDB Atlas (production) — uncomment and fill in:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/advanced_events?retryWrites=true&w=majority

# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET=change_this_to_a_long_random_string_in_production

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
